version 4
symboltype cell
rectangle Normal -16 -16 16 16
line Normal -48 32 -16 16
line Normal -48 -32 -16 -16
line Normal 16 0 48 0
window 0 0 -32 Center 2
symattr Prefix X
symattr Value MixedCase
pin -48 32 LEFT 8
pinattr PinName L+
pinattr SpiceOrder 1
pin -48 -32 LEFT 8
pinattr PinName L-
pinattr SpiceOrder 2
pin 48 0 RIGHT 8
pinattr PinName R
pinattr SpiceOrder 3
